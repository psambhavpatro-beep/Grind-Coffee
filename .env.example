# Roast & Origin — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# All VITE_ variables are bundled into the frontend (safe for public keys only).
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────

# ── Firebase ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── ImgBB (image upload) ──────────────────────────────────────────────
VITE_IMGBB_API_KEY=your_imgbb_api_key_here

# ── Admin Firebase Auth ───────────────────────────────────────────────
# Create this account in Firebase Console → Authentication
VITE_ADMIN_EMAIL=admin@your-project.com
VITE_ADMIN_PASSWORD=your_admin_firebase_password

# ── Razorpay (Payment Gateway) ────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys (rzp_test_...) during development — no real money moves
# Only the Key ID goes here (public). Key Secret goes in Firebase Secret Manager.
# Command: firebase functions:secrets:set RAZORPAY_KEY_ID
#          firebase functions:secrets:set RAZORPAY_KEY_SECRET
VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_ME

# ── Google Maps / Places Autocomplete ─────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API + Places API
# Restrict the key to your domain in production!
VITE_GOOGLE_MAPS_API_KEY=REPLACE_ME

# ── Shiprocket (Shipping & Tracking) ──────────────────────────────────
# Stored ONLY in Firebase Secret Manager — never in frontend .env
# Commands:
#   firebase functions:secrets:set SHIPROCKET_EMAIL
#   firebase functions:secrets:set SHIPROCKET_PASSWORD
