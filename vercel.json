{
    "redirects": [
        {
            "source": "/:path(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "grind-coffee-omega.vercel.app"
                }
            ],
            "destination": "https://thatsgrind.com/:path",
            "permanent": true
        }
    ],
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/product/:slug",
            "destination": "/api/product-page?slug=:slug"
        },
        {
            "source": "/merchant-feed.xml",
            "destination": "/api/merchant-feed"
        },
        {
            "source": "/about",
            "destination": "/about/index.html"
        },
        {
            "source": "/deliver/:slug",
            "destination": "/deliver/:slug/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}